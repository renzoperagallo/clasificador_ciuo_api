# URL base de la API NVIDIA NIM (OpenAI-compatible)
API_BASE_URL=https://integrate.api.nvidia.com/v1

# API Key de NVIDIA (obtenla en https://build.nvidia.com/explore/discover)
API_KEY=nvapi-tu-api-key-aqui

# Modelo a utilizar
MODEL_NAME=deepseek-ai/deepseek-v4-flash

# Parámetros de generación
TEMPERATURE=0.1
MAX_TOKENS=65536

# Tamaño del lote (número de glosas por llamada a la API)
# Con 500 glosas/lote se usa ~88K tokens de los 160K de contexto
BATCH_SIZE=500

# Número máximo de reintentos por lote ante errores transitorios
MAX_RETRIES=3

# Timeout por request en segundos (lotes grandes necesitan más tiempo)
REQUEST_TIMEOUT=1800
