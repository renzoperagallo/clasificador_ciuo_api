# URL base de la API (OpenAI-compatible)
API_BASE_URL=https://api.openai.com/v1

# API Key
API_KEY=sk-tu-api-key-aqui

# Modelo a utilizar
MODEL_NAME=gpt-4o

# Parámetros de generación
TEMPERATURE=0.1
MAX_TOKENS=4096

# Tamaño del lote (número de glosas por llamada a la API)
BATCH_SIZE=10

# Número máximo de reintentos por lote ante errores transitorios
MAX_RETRIES=3
